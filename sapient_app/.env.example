# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=opportunity-finder/0.1 by u/yourname

# Anthropic
ANTHROPIC_API_KEY=

# Postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opportunities

# Polling
POLL_INTERVAL_MINUTES=15
DRY_RUN=false
MIN_SCORE_TO_STORE=60

# Product config
PRODUCT_NAME=Acme Widget
PRODUCT_DESCRIPTION=Acme Widget helps small teams automate their X workflow. It connects to common tools and removes the manual copy-paste that slows people down.
PROBLEM_KEYWORDS=manual workflow,copy paste,stuck on,automating
SEED_SUBREDDITS=smallbusiness,startups,nocode
DISCOVER_ADJACENT_SUBREDDITS=true
