# Repo-wide defaults. Loaded by every service. Per-service files
# (.env.finder / .env.visibility / .env.dashboard) override values here.
#
# Copy this file to .env at the repo root before running docker-compose:
#   cp ops/env/.env.example .env

# Postgres — same instance for all three services. The Python URL form is
# the canonical one; the dashboard's drizzle layer wants a non-psycopg URL,
# so docker-compose hands it the postgres:// variant explicitly.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/opportunities
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opportunities

# Product config — finder + dashboard share product naming so guardrails
# detect the same product the finder scores against.
PRODUCT_NAME=Acme Widget
PRODUCT_DESCRIPTION=Acme Widget helps small teams automate their X workflow.
PRODUCT_TERMS=acme widget,acmewidget.com

# Logging
LOG_LEVEL=info
