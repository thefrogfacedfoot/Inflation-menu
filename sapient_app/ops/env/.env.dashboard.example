# Dashboard-only.
#
# DATABASE_URL is overridden in docker-compose.yml to the non-psycopg form
# that drizzle/postgres-js expects.

AUTH_SECRET=change-me-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

AUTH_REDDIT_ID=
AUTH_REDDIT_SECRET=

# Guardrail thresholds (mirror the spec defaults).
WEEKLY_PROMO_CAP=3
REMOVAL_RATE_THRESHOLD=0.20
REMOVAL_RATE_WINDOW=10

# DISCLOSURE_PHRASES=disclosure:|i work on|i'm one of the makers|[brand] employee
