COST_CAP_PERPLEXITY=200
COST_CAP_SERP=200
COST_CAP_REDDIT_SEARCH=0

COST_PER_RUN_CHATGPT=5
COST_PER_RUN_CLAUDE=20
COST_PER_RUN_GEMINI=2
COST_PER_RUN_PERPLEXITY=3
