# Same Postgres as the finder; isolated schema.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opportunities
VISIBILITY_DB_SCHEMA=visibility

# LLM source credentials
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# Models
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-opus-4-7
GEMINI_MODEL=gemini-1.5-pro
PERPLEXITY_MODEL=sonar

# SERP backend: serpapi | brave
SERP_BACKEND=serpapi
SERPAPI_KEY=
BRAVE_API_KEY=

# Reddit (for reddit_search source)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=visibility-tracker/0.1

# Per-source per-day cost caps, in USD cents. 0 = no cap.
COST_CAP_CHATGPT=500
COST_CAP_CLAUDE=1000
COST_CAP_GEMINI=200
COST_CAP_PERPLEXITY=200
COST_CAP_SERP=200
COST_CAP_REDDIT_SEARCH=0

# Estimated cost per run in USD cents.
COST_PER_RUN_CHATGPT=5
COST_PER_RUN_CLAUDE=20
COST_PER_RUN_GEMINI=2
COST_PER_RUN_PERPLEXITY=3
COST_PER_RUN_SERP=1
COST_PER_RUN_REDDIT_SEARCH=0

# Webhook fired when a per-day cap is hit.
COST_CAP_WEBHOOK_URL=

# Scheduling (cron-ish — APScheduler interval triggers)
SCHEDULE_LLM_HOURS=24
SCHEDULE_SERP_HOURS=168
SCHEDULE_REDDIT_HOURS=24
SCHEDULE_TASKS_HOURS=24
