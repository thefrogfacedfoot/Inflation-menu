# Same DB as the Python finder. Dashboard reads its `opportunities` table.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opportunities

# Auth.js
AUTH_SECRET=change-me-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Reddit OAuth (https://www.reddit.com/prefs/apps -> web app)
AUTH_REDDIT_ID=
AUTH_REDDIT_SECRET=

# Product config (mirrors the finder so guardrails can detect product mentions)
PRODUCT_NAME=Acme Widget
PRODUCT_TERMS=acme widget,acmewidget.com

# Guardrail thresholds (defaults match the spec)
WEEKLY_PROMO_CAP=3
REMOVAL_RATE_THRESHOLD=0.20
REMOVAL_RATE_WINDOW=10

# Optional: override disclosure phrases (pipe-separated, case-insensitive).
# "[brand]" expands to matched aliases at check time.
# DISCLOSURE_PHRASES=disclosure:|i work on|i'm one of the makers|[brand] employee
